# Exclude local dev and build files
node_modules/
.vscode/
.env
*.log
*.tsbuildinfo
.DS_Store

# Exclude test files
tests/
coverage/
*.test.ts
*.spec.ts
vitest.config.ts

# Exclude source (compiled to dist/)
src/

# Exclude config files
tsconfig.json
tsup.config.ts
eslint.config.js
.prettierrc
.prettierignore

# Exclude CI/CD and docs
.github/
.changeset/
docs/

# Exclude backup and editor-specific files
*.swp
*.swo
.idea/
*.bak

# Include only the compiled CLI and templates
!dist/
!extension-structure/
